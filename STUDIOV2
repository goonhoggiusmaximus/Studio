// ─── SNOWY FOREST ─────────────────────────────────────────────
(function(){
  const canvas=document.getElementById('snow-bg');
  const ctx=canvas.getContext('2d');
  let W,H,raf;

  // Snowflakes
  const FLAKE_COUNT=200;
  const flakes=[];

  function resize(){
    W=canvas.width=window.innerWidth;
    H=canvas.height=window.innerHeight;
    // reinit flakes on resize
    flakes.length=0;
    for(let i=0;i<FLAKE_COUNT;i++){
      flakes.push({
        x:Math.random()*W, y:Math.random()*H,
        r:0.8+Math.random()*3.2,
        speed:0.4+Math.random()*1.2,
        drift:(Math.random()-0.5)*0.6,
        opacity:0.4+Math.random()*0.6,
      });
    }
  }
  resize();window.addEventListener('resize',resize);

  function drawTree(x,groundY,height,layers,snowLoad){
    const trunkH=height*0.18;
    // trunk
    ctx.fillStyle='#4a3020';
    ctx.fillRect(x-4,groundY-trunkH,8,trunkH+2);
    // layers of pine boughs bottom to top
    for(let l=0;l<layers;l++){
      const ly=groundY-trunkH-(l*(height-trunkH)/layers);
      const lw=(1-(l/layers))*height*0.55+10;
      const lh=(height-trunkH)/layers*1.3;
      // dark pine green
      ctx.beginPath();
      ctx.moveTo(x,ly-lh);
      ctx.lineTo(x+lw,ly+4);
      ctx.lineTo(x-lw,ly+4);
      ctx.closePath();
      const treeGrad=ctx.createLinearGradient(x-lw,0,x+lw,0);
      treeGrad.addColorStop(0,'#1a3a1a');
      treeGrad.addColorStop(0.5,'#2a5a2a');
      treeGrad.addColorStop(1,'#1a3a1a');
      ctx.fillStyle=treeGrad;ctx.fill();

      // snow on branches
      const snowH=snowLoad*(lh*0.45);
      ctx.beginPath();
      ctx.moveTo(x-lw*0.9,ly+4);
      ctx.quadraticCurveTo(x-lw*0.4,ly+4-snowH*0.8,x,ly-lh*0.1);
      ctx.quadraticCurveTo(x+lw*0.4,ly+4-snowH*0.8,x+lw*0.9,ly+4);
      ctx.closePath();
      ctx.fillStyle='rgba(230,240,255,0.88)';ctx.fill();
    }
  }

  function drawFox(x,y){
    ctx.save();ctx.translate(x,y);
    // body
    ctx.fillStyle='#cc5500';
    ctx.beginPath();ctx.ellipse(0,0,18,10,0,0,Math.PI*2);ctx.fill();
    // white belly
    ctx.fillStyle='rgba(255,240,220,0.85)';
    ctx.beginPath();ctx.ellipse(2,2,10,6,0,0,Math.PI*2);ctx.fill();
    // head
    ctx.fillStyle='#cc5500';
    ctx.beginPath();ctx.ellipse(18,-3,11,9,0.15,0,Math.PI*2);ctx.fill();
    // snout
    ctx.fillStyle='#e8701a';
    ctx.beginPath();ctx.ellipse(27,-3,6,4,0,0,Math.PI*2);ctx.fill();
    // white snout tip
    ctx.fillStyle='rgba(255,245,235,0.9)';
    ctx.beginPath();ctx.ellipse(29,-2,3,2.5,0,0,Math.PI*2);ctx.fill();
    // nose
    ctx.fillStyle='#1a0a00';
    ctx.beginPath();ctx.ellipse(31,-2,1.5,1,0,0,Math.PI*2);ctx.fill();
    // eye — peaking out curiously
    ctx.fillStyle='#1a0a00';
    ctx.beginPath();ctx.arc(22,-6,2,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='rgba(255,255,255,0.7)';
    ctx.beginPath();ctx.arc(22.6,-6.4,0.7,0,Math.PI*2);ctx.fill();
    // ears
    ctx.fillStyle='#cc5500';
    ctx.beginPath();ctx.moveTo(16,-10);ctx.lineTo(12,-22);ctx.lineTo(22,-12);ctx.closePath();ctx.fill();
    ctx.beginPath();ctx.moveTo(22,-10);ctx.lineTo(20,-22);ctx.lineTo(28,-13);ctx.closePath();ctx.fill();
    ctx.fillStyle='#ff8844';
    ctx.beginPath();ctx.moveTo(17,-11);ctx.lineTo(14,-20);ctx.lineTo(21,-13);ctx.closePath();ctx.fill();
    ctx.beginPath();ctx.moveTo(23,-11);ctx.lineTo(21,-20);ctx.lineTo(27,-13);ctx.closePath();ctx.fill();
    // tail curling around
    ctx.strokeStyle='#cc5500';ctx.lineWidth=7;ctx.lineCap='round';
    ctx.beginPath();ctx.moveTo(-14,2);ctx.bezierCurveTo(-28,8,-30,-8,-18,-12);ctx.stroke();
    ctx.strokeStyle='rgba(255,245,235,0.8)';ctx.lineWidth=3;
    ctx.beginPath();ctx.moveTo(-14,2);ctx.bezierCurveTo(-28,8,-30,-8,-18,-12);ctx.stroke();
    // snow on head
    ctx.fillStyle='rgba(230,242,255,0.75)';
    ctx.beginPath();ctx.ellipse(18,-10,8,3,0.1,0,Math.PI);ctx.fill();
    ctx.restore();
  }

  function draw(){
    ctx.clearRect(0,0,W,H);

    // sky — cold blue-grey twilight
    const sky=ctx.createLinearGradient(0,0,0,H*0.65);
    sky.addColorStop(0,'#c8d8e8');
    sky.addColorStop(0.5,'#d8e8f2');
    sky.addColorStop(1,'#e0eef6');
    ctx.fillStyle=sky;ctx.fillRect(0,0,W,H*0.65);

    // distant mist/fog bank
    const fog=ctx.createLinearGradient(0,H*0.45,0,H*0.7);
    fog.addColorStop(0,'rgba(220,232,245,0)');
    fog.addColorStop(0.5,'rgba(220,232,245,0.5)');
    fog.addColorStop(1,'rgba(215,228,242,0)');
    ctx.fillStyle=fog;ctx.fillRect(0,H*0.45,W,H*0.3);

    const groundY=H*0.72;

    // snowy ground
    const ground=ctx.createLinearGradient(0,groundY,0,H);
    ground.addColorStop(0,'#ddeeff');
    ground.addColorStop(1,'#c8daf0');
    ctx.fillStyle=ground;
    ctx.beginPath();
    ctx.moveTo(0,groundY);
    // gentle undulating snow drifts
    for(let x=0;x<=W;x+=40){
      const dy=Math.sin(x*0.012)*14+Math.sin(x*0.025)*8;
      ctx.lineTo(x,groundY+dy);
    }
    ctx.lineTo(W,H);ctx.lineTo(0,H);ctx.closePath();ctx.fill();

    // ground surface highlight
    ctx.strokeStyle='rgba(255,255,255,0.6)';ctx.lineWidth=2;
    ctx.beginPath();
    for(let x=0;x<=W;x+=40){
      const dy=Math.sin(x*0.012)*14+Math.sin(x*0.025)*8;
      x===0?ctx.moveTo(0,groundY+dy):ctx.lineTo(x,groundY+dy);
    }
    ctx.stroke();

    // background trees (small, misty)
    ctx.globalAlpha=0.35;
    for(let t=0;t<8;t++){
      const tx=W*(0.05+t*0.12);
      drawTree(tx,groundY-10+Math.sin(t)*8,55+t%3*15,4,0.5);
    }
    ctx.globalAlpha=1;

    // mid trees
    ctx.globalAlpha=0.65;
    for(let t=0;t<6;t++){
      const tx=W*(0.04+t*0.175);
      drawTree(tx,groundY+5,75+t%3*20,5,0.7);
    }
    ctx.globalAlpha=1;

    // foreground trees — big and close
    const fgTrees=[
      {x:W*0.06, h:130, layers:6, snow:0.85},
      {x:W*0.18, h:155, layers:7, snow:0.9},
      {x:W*0.35, h:110, layers:5, snow:0.75},
      {x:W*0.62, h:145, layers:6, snow:0.88},
      {x:W*0.78, h:120, layers:6, snow:0.82},
      {x:W*0.92, h:140, layers:7, snow:0.9},
    ];
    fgTrees.forEach(t=>drawTree(t.x,groundY+12,t.h,t.layers,t.snow));

    // The fox — peeking from behind the 3rd foreground tree
    const foxTreeX=W*0.35;
    const foxY=groundY+6;
    // only show the right half of the fox (peeking)
    ctx.save();
    ctx.beginPath();ctx.rect(foxTreeX+4,foxY-40,W,80);ctx.clip();
    drawFox(foxTreeX-8,foxY-8);
    ctx.restore();

    // snowflakes
    flakes.forEach(f=>{
      ctx.save();ctx.globalAlpha=f.opacity;
      ctx.fillStyle='#fff';
      ctx.shadowColor='rgba(180,220,255,0.8)';ctx.shadowBlur=3;
      ctx.beginPath();ctx.arc(f.x,f.y,f.r,0,Math.PI*2);ctx.fill();
      ctx.restore();
      f.y+=f.speed;
      f.x+=f.drift;
      if(f.y>H+5){f.y=-5;f.x=Math.random()*W;}
      if(f.x>W+5) f.x=-5;
      if(f.x<-5) f.x=W+5;
    });

    if(document.body.classList.contains('theme-white')) raf=requestAnimationFrame(draw);
  }
  const obs=new MutationObserver(()=>{
    if(document.body.classList.contains('theme-white')){cancelAnimationFrame(raf);draw();}
    else cancelAnimationFrame(raf);
  });
  obs.observe(document.body,{attributes:true,attributeFilter:['class']});
  if(document.body.classList.contains('theme-white')) draw();
})();

