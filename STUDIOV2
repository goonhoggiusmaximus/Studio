// ── NOTE RENDERING ──────────────────────────────────────────
function renderNotes(genre, ti){
  const wrap=rollWraps[genre]&&rollWraps[genre][ti];
  if(!wrap)return;
  // remove old note blocks
  wrap.querySelectorAll('.note-block').forEach(n=>n.remove());
  const notes=melPat[genre][ti];
  const ROW_H=100/8; // percent per row
  const COL_W=100/STEPS; // percent per col
  notes.forEach((note,ni)=>{
    const block=document.createElement('div');
    block.className='note-block';
    block.style.background=TI_COLORS[ti];
    block.style.top=(note.row*ROW_H+0.5)+'%';
    block.style.height=(ROW_H-1)+'%';
    block.style.left=(note.start*COL_W+0.3)+'%';
    block.style.width=(note.len*COL_W-0.6)+'%';
    block.dataset.ni=ni;

    // delete on click (without drag)
    let moved=false;
    block.addEventListener('mousedown',e=>{moved=false;e.stopPropagation();});
    block.addEventListener('mousemove',()=>moved=true);
    block.addEventListener('mouseup',e=>{
      if(!moved&&!e.target.classList.contains('drag-handle')){
        melPat[genre][ti].splice(ni,1);
        renderNotes(genre,ti);
      }
    });

    // resize handle
    const handle=document.createElement('div');
    handle.className='drag-handle';
    handle.addEventListener('mousedown',e=>{
      e.stopPropagation();
      e.preventDefault();
      const startX=e.clientX;
      const origLen=note.len;
      const colPx=wrap.getBoundingClientRect().width/STEPS;
      function onMove(ev){
        const delta=Math.round((ev.clientX-startX)/colPx);
        note.len=Math.max(1,Math.min(STEPS-note.start,origLen+delta));
        renderNotes(genre,ti);
      }
      function onUp(){window.removeEventListener('mousemove',onMove);window.removeEventListener('mouseup',onUp);}
      window.addEventListener('mousemove',onMove);
      window.addEventListener('mouseup',onUp);
    });
    block.appendChild(handle);
    wrap.appendChild(block);
  });
}

// ── ROLL INTERACTION ────────────────────────────────────────
function attachRollEvents(wrap, genre, ti){
  let painting=false, paintNote=null;

  wrap.addEventListener('mousedown',e=>{
    if(e.target.classList.contains('note-block')||e.target.classList.contains('drag-handle'))return;
    const cell=e.target.closest('.roll-cell');
    if(!cell)return;
    e.preventDefault();
    const ri=parseInt(cell.dataset.ri);
    const si=parseInt(cell.dataset.si);
    // check if clicking on existing note at this cell — skip (handled by note block)
    painting=true;
    paintNote={row:ri,start:si,len:1};
    melPat[genre][ti].push(paintNote);
    renderNotes(genre,ti);
  });

  wrap.addEventListener('mousemove',e=>{
    if(!painting||!paintNote)return;
    const cell=e.target.closest('.roll-cell');
    if(!cell)return;
    const si=parseInt(cell.dataset.si);
    if(si>=paintNote.start){
      paintNote.len=si-paintNote.start+1;
      renderNotes(genre,ti);
    }
  });

  window.addEventListener('mouseup',()=>{
    if(painting){painting=false;paintNote=null;}
  });
}

