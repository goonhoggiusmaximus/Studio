(function(){
  const btn=document.getElementById('recordBtn');
  const label=document.getElementById('recBtnLabel');
  const status=document.getElementById('recStatus');
  const progressWrap=document.getElementById('rec-progress');
  const bar=document.getElementById('rec-bar');
  let recording=false,recDest=null,recCtx=null,recChunks=[];

  btn.addEventListener('click',async()=>{
    if(recording){
      // Stop early
      finishRecording();
      return;
    }
    recording=true;
    btn.classList.add('recording');
    label.textContent='STOP RECORDING';
    status.textContent='INITIALIZING...';
    progressWrap.style.display='block';
    bar.style.width='0%';

    const ctx=getCtx();
    // Record exactly one loop length
    const loopDuration=(60/bpm/4)*STEPS;
    const offlineCtx=new OfflineAudioContext(2,Math.ceil(ctx.sampleRate*loopDuration*1.05),ctx.sampleRate);

    // Render loop offline
    status.textContent='RENDERING...';

    // We'll render by scheduling all events manually into the offline context
    const masterG=offlineCtx.createGain();masterG.gain.value=masterVol;masterG.connect(offlineCtx.destination);

    // Helper to get offline reverb
    const rLen=offlineCtx.sampleRate*2,rBuf=offlineCtx.createBuffer(2,rLen,offlineCtx.sampleRate);
    for(let ch=0;ch<2;ch++){const d=rBuf.getChannelData(ch);for(let i=0;i<rLen;i++)d[i]=(Math.random()*2-1)*Math.pow(1-i/rLen,2);}
    const offRev=offlineCtx.createConvolver();offRev.buffer=rBuf;
    const offRevG=offlineCtx.createGain();offRevG.gain.value=masterRevSend*1.2;
    offRevG.connect(offRev);offRev.connect(offlineCtx.destination);
    masterG.connect(offRevG);

    function scheduleOsc(freq,startT,dur,type,filterFreq,gainVal,detuneCents){
      try{
        const o=offlineCtx.createOscillator();const g=offlineCtx.createGain();
        o.type=type||'sine';o.frequency.value=freq;
        if(detuneCents)o.detune.value=detuneCents;
        if(filterFreq){const f=offlineCtx.createBiquadFilter();f.type='lowpass';f.frequency.value=filterFreq;o.connect(f);f.connect(g);}
        else o.connect(g);
        g.gain.setValueAtTime(0,startT);g.gain.linearRampToValueAtTime(gainVal||0.3,startT+0.01);
        g.gain.setTargetAtTime(0,startT+dur*0.8,dur*0.08);
        g.connect(masterG);
        o.start(startT);o.stop(startT+dur+0.1);
      }catch(e){}
    }

    const sStep=60/bpm/4;
    // Drums
    for(let step=0;step<STEPS;step++){
      const t=step*sStep;
      const swingOff=(step%2===1)?swingAmt*sStep*0.5:0;
      const tt=t+swingOff;
      if(drumPat[0][step]){// kick
        scheduleOsc(60,tt,0.4,'sine',200,0.5,0);
        scheduleOsc(80,tt,0.15,'square',120,0.3,0);
      }
      if(drumPat[1][step]){// snare - noise burst
        const nb=offlineCtx.createBufferSource();const nb2=offlineCtx.createBuffer(1,offlineCtx.sampleRate*0.2,offlineCtx.sampleRate);
        const nd=nb2.getChannelData(0);for(let i=0;i<nd.length;i++)nd[i]=(Math.random()*2-1);
        nb.buffer=nb2;const ng=offlineCtx.createGain();ng.gain.setValueAtTime(0.35,tt);ng.gain.exponentialRampToValueAtTime(0.001,tt+0.18);
        const nhp=offlineCtx.createBiquadFilter();nhp.type='highpass';nhp.frequency.value=1800;
        nb.connect(nhp);nhp.connect(ng);ng.connect(masterG);
        try{nb.start(tt);nb.stop(tt+0.22);}catch(e){}
      }
      if(drumPat[2][step]){// hihat
        const nb=offlineCtx.createBufferSource();const nb2=offlineCtx.createBuffer(1,offlineCtx.sampleRate*0.08,offlineCtx.sampleRate);
        const nd=nb2.getChannelData(0);for(let i=0;i<nd.length;i++)nd[i]=(Math.random()*2-1);
        nb.buffer=nb2;const ng=offlineCtx.createGain();ng.gain.setValueAtTime(0.2,tt);ng.gain.exponentialRampToValueAtTime(0.001,tt+0.07);
        const nhp=offlineCtx.createBiquadFilter();nhp.type='highpass';nhp.frequency.value=8000;
        nb.connect(nhp);nhp.connect(ng);ng.connect(masterG);
        try{nb.start(tt);nb.stop(tt+0.1);}catch(e){}
      }
      if(drumPat[3][step]){// clap
        for(let c=0;c<3;c++){
          const cb=offlineCtx.createBufferSource();const cb2=offlineCtx.createBuffer(1,offlineCtx.sampleRate*0.06,offlineCtx.sampleRate);
          const cd=cb2.getChannelData(0);for(let i=0;i<cd.length;i++)cd[i]=(Math.random()*2-1);
          cb.buffer=cb2;const cg=offlineCtx.createGain();cg.gain.setValueAtTime(0.25,tt+c*0.012);cg.gain.exponentialRampToValueAtTime(0.001,tt+c*0.012+0.05);
          const chp=offlineCtx.createBiquadFilter();chp.type='bandpass';chp.frequency.value=1200;
          cb.connect(chp);chp.connect(cg);cg.connect(masterG);
          try{cb.start(tt+c*0.012);cb.stop(tt+c*0.012+0.08);}catch(e){}
        }
      }
    }
    // Melody
    const genre=currentGenre;
    GENRES[genre].forEach((tr,ti)=>{
      melPat[genre][ti].forEach(note=>{
        const t=note.start*sStep;
        const swingOff=(note.start%2===1)?swingAmt*sStep*0.5:0;
        const tt=t+swingOff;
        const dur=note.len*sStep*0.88;
        const freq=noteFreq(note.row,melOct[genre][ti],genre);
        const p=instP[genre][ti];
        // simplified synthesis for offline
        const types={synth:'sawtooth',bass:'square',lead:'triangle',pad:'sine',egtr:'sawtooth',bassgtr:'triangle',power:'sawtooth',organ:'sine',acoustic:'triangle',banjo:'triangle',fiddle:'sawtooth',steel:'sine'};
        const t2=types[tr.key]||'sine';
        scheduleOsc(freq,tt,dur,t2,tr.key==='synth'?800:tr.key==='bass'?300:4000,0.22,p.detune*50);
        if(tr.key==='pad'){scheduleOsc(freq*1.003,tt,dur,'sine',2000,0.12,7);}
      });
    });

    // Render
    let animId;
    let progress=0;
    function animBar(){bar.style.width=(progress*100)+'%';if(progress<1)animId=requestAnimationFrame(animBar);}
    const incr=1/(loopDuration*60);
    const progInterval=setInterval(()=>{progress=Math.min(0.98,progress+incr);},1000/60);
    animBar();

    try{
      const renderedBuf=await offlineCtx.startRendering();
      clearInterval(progInterval);cancelAnimationFrame(animId);bar.style.width='100%';

      // Convert to WAV
      const numCh=renderedBuf.numberOfChannels;
      const len=renderedBuf.length;
      const sr=renderedBuf.sampleRate;
      const wavBuf=new ArrayBuffer(44+len*numCh*2);
      const view=new DataView(wavBuf);
      function ws(o,s){for(let i=0;i<s.length;i++)view.setUint8(o+i,s.charCodeAt(i));}
      function wu16(o,v){view.setUint16(o,v,true);}
      function wu32(o,v){view.setUint32(o,v,true);}
      ws(0,'RIFF');wu32(4,36+len*numCh*2);ws(8,'WAVE');ws(12,'fmt ');
      wu32(16,16);wu16(20,1);wu16(22,numCh);wu32(24,sr);wu32(28,sr*numCh*2);wu16(32,numCh*2);wu16(34,16);
      ws(36,'data');wu32(40,len*numCh*2);
      let offset=44;
      for(let i=0;i<len;i++){
        for(let ch=0;ch<numCh;ch++){
          const s=Math.max(-1,Math.min(1,renderedBuf.getChannelData(ch)[i]));
          view.setInt16(offset,s<0?s*0x8000:s*0x7FFF,true);offset+=2;
        }
      }
      const blob=new Blob([wavBuf],{type:'audio/wav'});
      const url=URL.createObjectURL(blob);
      const a=document.createElement('a');a.href=url;a.download='studio-loop.wav';a.click();
      setTimeout(()=>URL.revokeObjectURL(url),5000);
      status.textContent='✓ DOWNLOADED';
    }catch(err){
      status.textContent='ERROR: '+err.message;
    }
    setTimeout(()=>{
      recording=false;btn.classList.remove('recording');label.textContent='RECORD LOOP';
      progressWrap.style.display='none';bar.style.width='0%';
      setTimeout(()=>{status.textContent='';},2000);
    },800);
  });
})();
buildMelody('electronic');
buildInstPanel('electronic');
randDrums();
randMelody();
</script>
