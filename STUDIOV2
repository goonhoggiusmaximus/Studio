// rollWraps[genre][ti] = the .roll-wrap element for re-rendering notes
const rollWraps={};

const TI_COLORS=['var(--accent1)','var(--accent2)','var(--accent3)','color-mix(in srgb,var(--accent1) 55%,var(--accent2))'];

function buildMelody(genre){
