<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>STUDIO</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Share+Tech+Mono&family=Special+Elite&family=Courier+Prime:ital,wght@0,400;0,700;1,400&family=Cinzel+Decorative:wght@700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Playfair+Display:ital,wght@0,700;1,700&family=Snowburst+One&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}

/* ── THEMES ── */
body.theme-default { --bg:#080810;--panel:#0e0e1a;--border:#1e1e32;--accent1:#BF5AF2;--accent2:#FF3B30;--accent3:#00D4FF;--text:#ffffff;--text2:#555;--glow:rgba(191,90,242,0.25); }
body.theme-red     { --bg:#100505;--panel:#180808;--border:#3a1010;--accent1:#FF2020;--accent2:#FF6060;--accent3:#FF9090;--text:#ffe0e0;--text2:#663333;--glow:rgba(255,40,40,0.3); }
body.theme-matrix  { --bg:#041008;--panel:#081a0e;--border:#0f3018;--accent1:#00FF88;--accent2:#30D158;--accent3:#80FFB0;--text:#e0ffe8;--text2:#1a4428;--glow:rgba(0,255,136,0.25); }
body.theme-nautical{ --bg:#020d14;--panel:#051622;--border:#0a2a38;--accent1:#00C8FF;--accent2:#0088CC;--accent3:#80E4FF;--text:#e0f8ff;--text2:#0a3a50;--glow:rgba(0,200,255,0.25); }
body.theme-purple  { --bg:#08040f;--panel:#120820;--border:#200a3a;--accent1:#8B00FF;--accent2:#BB44FF;--accent3:#DD99FF;--text:#f0e0ff;--text2:#3a1060;--glow:rgba(139,0,255,0.3); }
body.theme-wine    { --bg:#0d0208;--panel:#1a0510;--border:#380a20;--accent1:#AA1155;--accent2:#DD3377;--accent3:#FF88AA;--text:#ffe0ec;--text2:#5a1030;--glow:rgba(170,17,85,0.3); }
body.theme-galaxy  { --bg:#020008;--panel:#07021a;--border:#130835;--accent1:#4466FF;--accent2:#8844FF;--accent3:#AACCFF;--text:#e8eeff;--text2:#1a1650;--glow:rgba(68,102,255,0.3); }
body.theme-white   { --bg:#dce8f0;--panel:#eaf2f8;--border:#b8d0e0;--accent1:#2e6fa0;--accent2:#1a4f78;--accent3:#5a9fc0;--text:#0d2030;--text2:#5a7a90;--glow:rgba(46,111,160,0.2); }

/* ── PER-THEME FONT OVERRIDES ── */
/* Default: Bebas Neue + Share Tech Mono — no override needed */

/* Red: same fonts, bold+italic everything */
body.theme-red { font-style:italic; font-weight:700; }
body.theme-red h1 { font-style:italic; }
body.theme-red .play-btn,body.theme-red .small-btn,body.theme-red .icon-btn,
body.theme-red .ctrl-label,body.theme-red .bpm-val,body.theme-red .drum-label,
body.theme-red .mel-label,body.theme-red .genre-tab,body.theme-red .inst-name,
body.theme-red .knob-lbl,body.theme-red .oct-display,body.theme-red .section-title
{ font-style:italic; font-weight:700; }

/* Matrix: Courier Prime typewriter */
body.theme-matrix { font-family:'Courier Prime',monospace !important; }
body.theme-matrix h1 { font-family:'Courier Prime',monospace; font-size:clamp(28px,5vw,58px); letter-spacing:0.15em; }
body.theme-matrix .play-btn,body.theme-matrix .small-btn,body.theme-matrix .icon-btn,
body.theme-matrix .key-sel,body.theme-matrix .genre-tab { font-family:'Courier Prime',monospace; }

/* Nautical: Special Elite rough slab */
body.theme-nautical { font-family:'Special Elite',cursive !important; }
body.theme-nautical h1 { font-family:'Special Elite',cursive; font-size:clamp(28px,5.5vw,60px); letter-spacing:0.12em; }
body.theme-nautical .play-btn,body.theme-nautical .small-btn,body.theme-nautical .icon-btn,
body.theme-nautical .key-sel,body.theme-nautical .genre-tab { font-family:'Special Elite',cursive; }

/* Deep Purple: Cormorant Garamond romantic serif */
body.theme-purple { font-family:'Cormorant Garamond',serif !important; }
body.theme-purple h1 { font-family:'Cinzel Decorative',serif; font-size:clamp(22px,4.5vw,52px); letter-spacing:0.2em; font-weight:700; }
body.theme-purple .play-btn,body.theme-purple .small-btn,body.theme-purple .icon-btn,
body.theme-purple .key-sel,body.theme-purple .genre-tab { font-family:'Cormorant Garamond',serif; font-size:12px; }

/* Wine Red: Playfair Display ultra fancy */
body.theme-wine { font-family:'Playfair Display',serif !important; }
body.theme-wine h1 { font-family:'Playfair Display',serif; font-style:italic; font-size:clamp(28px,5.5vw,64px); letter-spacing:0.15em; }
body.theme-wine .play-btn,body.theme-wine .small-btn,body.theme-wine .icon-btn,
body.theme-wine .key-sel,body.theme-wine .genre-tab { font-family:'Playfair Display',serif; }

/* ── THEME BACKGROUND LAYERS ── */
/* Matrix rain canvas */
#matrix-bg{position:fixed;inset:0;pointer-events:none;z-index:0;display:none;opacity:0.55;}
body.theme-matrix #matrix-bg{display:block;}

/* Nautical scene canvas */
#nautical-bg{position:fixed;inset:0;pointer-events:none;z-index:0;display:none;}
body.theme-nautical #nautical-bg{display:block;}

/* Wine roses */
#wine-bg{position:fixed;inset:0;pointer-events:none;z-index:0;display:none;overflow:hidden;}
body.theme-wine #wine-bg{display:block;}
.rose{position:absolute;top:-60px;font-size:var(--rs,22px);animation:rose-fall var(--rd,8s) linear var(--rdelay,0s) infinite;opacity:0.7;user-select:none;}
@keyframes rose-fall{
  0%{transform:translateY(-60px) rotate(0deg) translateX(0px);opacity:0;}
  5%{opacity:0.75;}
  90%{opacity:0.6;}
  100%{transform:translateY(110vh) rotate(var(--rrot,360deg)) translateX(var(--rx,30px));opacity:0;}
}

/* Snowy forest canvas */
#snow-bg{position:fixed;inset:0;pointer-events:none;z-index:0;display:none;}
body.theme-white #snow-bg{display:block;}

/* White theme: Snowburst One font, italic */
body.theme-white { font-family:'Snowburst One',cursive !important; font-style:italic; }
body.theme-white h1 { font-family:'Snowburst One',cursive; font-style:italic; font-size:clamp(26px,5vw,58px); letter-spacing:0.2em; text-shadow:0 2px 12px rgba(180,220,255,0.7),0 0 30px rgba(46,111,160,0.3); }
body.theme-white .play-btn,body.theme-white .small-btn,body.theme-white .icon-btn,
body.theme-white .key-sel,body.theme-white .genre-tab,body.theme-white .ctrl-label,
body.theme-white .bpm-val,body.theme-white .drum-label,body.theme-white .mel-label,
body.theme-white .section-title,body.theme-white .inst-name,body.theme-white .knob-lbl
{ font-family:'Snowburst One',cursive; font-style:italic; }

body{
  background:var(--bg);color:var(--text);
  font-family:'Share Tech Mono',monospace;
  min-height:100vh;display:flex;flex-direction:column;align-items:center;
  padding:16px 14px 50px;overflow-x:hidden;
  transition:background 0.4s,color 0.4s;
}
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.08) 2px,rgba(0,0,0,0.08) 4px);pointer-events:none;z-index:200;}

/* Galaxy background */
#galaxy-bg{position:fixed;inset:0;pointer-events:none;z-index:0;display:none;}
body.theme-galaxy #galaxy-bg{display:block;}
.star{position:absolute;border-radius:50%;background:#fff;animation:twinkle var(--dur,3s) ease-in-out infinite;}
@keyframes twinkle{0%,100%{opacity:0.15;transform:scale(1);}50%{opacity:1;transform:scale(1.5);}}

/* Planets */
.planet{
  position:absolute;border-radius:50%;
  animation:float-planet var(--fdur,60s) ease-in-out infinite alternate;
}
@keyframes float-planet{0%{transform:translateY(0px) rotate(0deg);}100%{transform:translateY(var(--fy,12px)) rotate(var(--fr,8deg));}}
.planet .ring{
  position:absolute;border-radius:50%;
  border:var(--rw,3px) solid rgba(255,255,255,0.18);
  top:50%;left:50%;
  transform:translate(-50%,-50%) rotateX(70deg);
  pointer-events:none;
}

/* Black holes */
.blackhole{
  position:absolute;border-radius:50%;
  background:radial-gradient(circle,#000 30%,transparent 70%);
  animation:bh-pulse var(--bhdur,8s) ease-in-out infinite;
}
.blackhole::before{
  content:'';position:absolute;inset:-40%;border-radius:50%;
  background:conic-gradient(from 0deg,transparent 60%,rgba(80,40,200,0.15) 80%,transparent 100%);
  animation:bh-spin var(--bhdur,8s) linear infinite;
}
.blackhole::after{
  content:'';position:absolute;inset:-20%;border-radius:50%;
  box-shadow:0 0 30px 8px rgba(60,20,180,0.25),0 0 60px 20px rgba(30,10,120,0.12);
}
@keyframes bh-pulse{0%,100%{box-shadow:0 0 20px 6px rgba(40,0,120,0.4);}50%{box-shadow:0 0 40px 14px rgba(80,20,200,0.55);}}
@keyframes bh-spin{0%{transform:rotate(0deg);}100%{transform:rotate(360deg);}}

/* ── LAYOUT ── */
.wrap{width:100%;max-width:980px;position:relative;z-index:10;}

header{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;}
h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(36px,7vw,72px);letter-spacing:0.25em;color:var(--text);text-shadow:0 0 30px var(--glow);}
.subtitle{font-size:10px;color:var(--text2);letter-spacing:0.35em;margin-bottom:14px;}

/* ── TOP BAR ── */
.top-bar{
  display:flex;align-items:center;gap:12px;flex-wrap:wrap;
  background:var(--panel);border:1px solid var(--border);border-radius:6px;
  padding:10px 16px;margin-bottom:12px;
  transition:background 0.4s,border-color 0.4s;
}
.ctrl-label{font-size:9px;color:var(--text2);letter-spacing:0.2em;}
.bpm-val{color:var(--accent1);font-size:15px;min-width:34px;text-align:center;}
.icon-btn{background:none;border:1px solid var(--border);color:var(--text2);width:22px;height:22px;cursor:pointer;font-family:inherit;font-size:11px;border-radius:3px;display:flex;align-items:center;justify-content:center;transition:all 0.1s;}
.icon-btn:hover{border-color:var(--accent1);color:var(--accent1);}
.play-btn{font-family:'Share Tech Mono',monospace;font-size:11px;letter-spacing:0.15em;padding:7px 22px;border:none;cursor:pointer;border-radius:3px;background:var(--accent2);color:#fff;transition:all 0.12s;font-weight:bold;}
.play-btn:hover{filter:brightness(1.2);box-shadow:0 0 16px var(--glow);}
.play-btn.on{background:var(--border);color:var(--text2);}
.small-btn{font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:0.12em;padding:5px 12px;border:1px solid var(--border);background:transparent;color:var(--text2);cursor:pointer;border-radius:3px;transition:all 0.1s;}
.small-btn:hover{color:var(--text);border-color:var(--text2);}
.sep{width:1px;height:22px;background:var(--border);margin:0 2px;}
.key-sel{background:var(--panel);border:1px solid var(--border);color:var(--accent1);font-family:'Share Tech Mono',monospace;font-size:10px;padding:3px 7px;border-radius:3px;cursor:pointer;appearance:none;letter-spacing:0.1em;}

/* ── MASTER VOLUME KNOB ── */
.master-vol{display:flex;flex-direction:column;align-items:center;gap:4px;}
.master-knob{
  width:38px;height:38px;border-radius:50%;
  background:conic-gradient(var(--accent1) 0deg,var(--accent1) var(--deg,260deg),var(--border) var(--deg,260deg));
  cursor:ns-resize;border:2px solid var(--border);position:relative;
  transition:box-shadow 0.1s;
}
.master-knob:hover{box-shadow:0 0 14px var(--glow);}
.master-knob::after{content:'';position:absolute;width:3px;height:11px;background:var(--text);top:3px;left:50%;border-radius:2px;transform-origin:bottom center;transform:translateX(-50%) rotate(var(--rot,0deg));}
.knob-lbl{font-size:8px;color:var(--text2);letter-spacing:0.1em;}

/* ── THEME PICKER ── */
.theme-row{display:flex;gap:6px;align-items:center;}

/* ── SECTION ── */
.section-title{font-size:9px;letter-spacing:0.3em;color:var(--text2);margin:10px 0 6px;display:flex;align-items:center;gap:10px;}
.section-title::after{content:'';flex:1;height:1px;background:var(--border);}

/* ── DRUMS ── */
.drum-wrap{background:var(--panel);border:1px solid var(--border);border-radius:6px;padding:12px 14px;margin-bottom:12px;transition:background 0.4s,border-color 0.4s;}
.drum-track{display:grid;grid-template-columns:76px repeat(16,1fr);gap:3px;align-items:center;margin-bottom:3px;}
.drum-label{font-size:9px;letter-spacing:0.1em;color:var(--text2);text-align:right;padding-right:8px;display:flex;align-items:center;justify-content:flex-end;gap:4px;}
.drum-label .dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}

/* base step cell — just a container */
.step{
  aspect-ratio:1;display:flex;align-items:center;justify-content:center;
  cursor:pointer;background:transparent;border:none;
  position:relative;
}
.step.g4{margin-left:3px;}

/* the shape inside each step */
.step-shape{
  width:78%;height:78%;
  display:flex;align-items:center;justify-content:center;
  transition:background 0.08s, filter 0.08s;
  position:relative;
}

/* KICK — square */
.c0 .step-shape{
  background:color-mix(in srgb,var(--border) 90%,transparent);
  border:1px solid var(--border);
  border-radius:2px;
}
.c0.active .step-shape{background:var(--accent2);border-color:var(--accent2);box-shadow:0 0 6px var(--accent2);}

/* SNARE — triangle via clip-path */
.c1 .step-shape{
  background:color-mix(in srgb,var(--border) 90%,transparent);
  border:none;
  clip-path:polygon(50% 4%, 98% 96%, 2% 96%);
  border-radius:0;
}
.c1.active .step-shape{background:var(--accent1);box-shadow:0 0 6px var(--accent1);}

/* HIHAT — decagon via clip-path */
.c2 .step-shape{
  background:color-mix(in srgb,var(--border) 90%,transparent);
  border:none;
  clip-path:polygon(50% 0%,81% 9%,100% 35%,100% 65%,81% 91%,50% 100%,19% 91%,0% 65%,0% 35%,19% 9%);
  border-radius:0;
}
.c2.active .step-shape{background:var(--accent3);box-shadow:0 0 6px var(--accent3);}

/* CLAP — circle */
.c3 .step-shape{
  background:color-mix(in srgb,var(--border) 90%,transparent);
  border:1px solid var(--border);
  border-radius:50%;
}
.c3.active .step-shape{background:var(--accent1);border-color:var(--accent1);box-shadow:0 0 6px var(--accent1);}

/* ── BEAT ANIMATIONS ── */

/* KICK: pound down + white flash */
@keyframes kick-hit{
  0%  {transform:scale(1) rotate(0deg);filter:brightness(1);}
  15% {transform:scale(0.82) rotate(-4deg);filter:brightness(3);}
  30% {transform:scale(1.1) rotate(3deg);filter:brightness(1);}
  50% {transform:scale(0.95) rotate(-2deg);}
  70% {transform:scale(1.03) rotate(1deg);}
  100%{transform:scale(1) rotate(0deg);filter:brightness(1);}
}
/* shake on the step container */
@keyframes kick-shake{
  0%  {transform:translate(0,0);}
  15% {transform:translate(-2px,2px);}
  30% {transform:translate(2px,-1px);}
  50% {transform:translate(-1px,1px);}
  70% {transform:translate(1px,0px);}
  100%{transform:translate(0,0);}
}
.c0.beat-hit{animation:kick-shake 0.22s ease-out forwards;}
.c0.beat-hit .step-shape{animation:kick-hit 0.22s ease-out forwards;background:#fff !important;filter:brightness(3);}

/* SNARE: tilt + white flash */
@keyframes snare-hit{
  0%  {transform:rotate(0deg) scale(1);filter:brightness(1);}
  12% {transform:rotate(-18deg) scale(1.05);filter:brightness(4);}
  28% {transform:rotate(14deg) scale(0.96);}
  50% {transform:rotate(-8deg) scale(1.02);}
  75% {transform:rotate(5deg);}
  100%{transform:rotate(0deg) scale(1);filter:brightness(1);}
}
.c1.beat-hit .step-shape{animation:snare-hit 0.25s cubic-bezier(.2,1.5,.4,1) forwards;background:#fff !important;}

/* HIHAT: snap expand + rotate back-forth */
@keyframes hihat-hit{
  0%  {transform:scale(1) rotate(0deg);filter:brightness(1);}
  10% {transform:scale(1.35) rotate(20deg);filter:brightness(3.5);}
  25% {transform:scale(0.9) rotate(-15deg);}
  45% {transform:scale(1.1) rotate(10deg);}
  65% {transform:scale(0.97) rotate(-6deg);}
  82% {transform:scale(1.02) rotate(3deg);}
  100%{transform:scale(1) rotate(0deg);filter:brightness(1);}
}
.c2.beat-hit .step-shape{animation:hihat-hit 0.28s cubic-bezier(.15,1.4,.35,1) forwards;background:#fff !important;}

/* CLAP: flash white + scale pulse */
@keyframes clap-hit{
  0%  {transform:scale(1);filter:brightness(1);}
  10% {transform:scale(1.22);filter:brightness(4);}
  30% {transform:scale(0.88);}
  55% {transform:scale(1.08);}
  80% {transform:scale(0.97);}
  100%{transform:scale(1);filter:brightness(1);}
}
.c3.beat-hit .step-shape{animation:clap-hit 0.2s ease-out forwards;background:#fff !important;}

/* idle sway — always on for active steps */
@keyframes idle-sway{
  0%,100%{transform:rotate(-3deg);}
  50%{transform:rotate(3deg);}
}

.ph-row{display:grid;grid-template-columns:76px repeat(16,1fr);gap:3px;margin-bottom:5px;}
.ph-cell{height:3px;background:var(--border);border-radius:1px;transition:background 0.04s;}
.ph-cell.lit{background:var(--accent2);box-shadow:0 0 8px var(--accent2);}

/* ── VISUALIZER ── */
.visualizer{
  width:100%;height:80px;background:var(--panel);
  border:1px solid var(--border);border-radius:6px;
  margin-bottom:12px;position:relative;overflow:hidden;
  display:flex;align-items:flex-end;padding:4px 6px;gap:2px;
}
.vis-bar{flex:1;border-radius:2px 2px 0 0;min-height:2px;transition:height 0.06s ease-out;background:var(--accent1);}
.vis-line{position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--border);}

/* ── GENRE TABS ── */
.genre-tabs{display:flex;gap:0;margin-bottom:0;border-bottom:1px solid var(--border);}
.genre-tab{font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:0.2em;padding:8px 18px;cursor:pointer;border:1px solid transparent;border-bottom:none;border-radius:4px 4px 0 0;color:var(--text2);background:transparent;transition:all 0.15s;margin-bottom:-1px;}
.genre-tab:hover{color:var(--text);}
.genre-tab.active{background:var(--panel);border-color:var(--border);color:var(--accent1);border-bottom-color:var(--panel);}

/* ── MELODY WRAP ── */
.melody-outer{background:var(--panel);border:1px solid var(--border);border-radius:0 6px 6px 6px;padding:12px 14px;margin-bottom:12px;transition:background 0.4s,border-color 0.4s;}
.melody-track{display:grid;grid-template-columns:76px 1fr;gap:8px;align-items:start;margin-bottom:8px;}
.mel-label{font-size:9px;letter-spacing:0.1em;color:var(--text2);text-align:right;padding-right:8px;padding-top:5px;display:flex;align-items:flex-start;justify-content:flex-end;gap:4px;}

/* Piano roll: fixed grid of empty cells + absolute note blocks on top */
.roll-wrap{position:relative;height:96px;user-select:none;}
.roll-grid{
  display:grid;
  grid-template-columns:repeat(16,1fr);
  grid-template-rows:repeat(8,1fr);
  gap:2px;
  width:100%;height:100%;
  position:absolute;inset:0;
}
.roll-cell{
  background:color-mix(in srgb,var(--border) 55%,transparent);
  border-radius:2px;
  cursor:crosshair;
}
.roll-cell:hover{background:var(--border);}
/* group dividers every 4 cols */
.roll-cell.gc{margin-left:1px;}

/* note blocks rendered absolutely */
.note-block{
  position:absolute;
  border-radius:3px;
  cursor:pointer;
  box-sizing:border-box;
  border:1px solid rgba(255,255,255,0.25);
  display:flex;align-items:center;
  overflow:hidden;
  transition:filter 0.05s;
  z-index:5;
  min-width:4px;
}
.note-block:hover{filter:brightness(1.3);}
.note-block .drag-handle{
  position:absolute;right:0;top:0;bottom:0;
  width:6px;cursor:ew-resize;
  background:rgba(255,255,255,0.15);
  border-left:1px solid rgba(255,255,255,0.2);
}
.note-block.flash-note{filter:brightness(2.5)!important;}

.pr-col-hl{position:absolute;top:0;bottom:0;width:calc(100%/16 - 2px);background:rgba(255,255,255,0.05);border-radius:2px;pointer-events:none;transition:left 0.04s;z-index:3;}

/* ── INSTRUMENT PANEL ── */
.inst-panel{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px;}
.inst-card{background:var(--panel);border:1px solid var(--border);border-radius:6px;padding:10px 10px;transition:background 0.4s,border-color 0.4s;}
.inst-name{font-size:10px;letter-spacing:0.18em;margin-bottom:8px;display:flex;align-items:center;gap:5px;color:var(--text);}
.knob-row{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;}
.knob-group{display:flex;flex-direction:column;align-items:center;gap:3px;}
.knob{width:30px;height:30px;border-radius:50%;background:conic-gradient(var(--accent1) 0deg,var(--accent1) var(--deg,180deg),var(--border) var(--deg,180deg));cursor:ns-resize;position:relative;border:2px solid var(--border);transition:box-shadow 0.1s;}
.knob:hover{box-shadow:0 0 10px var(--glow);}
.knob::after{content:'';position:absolute;width:3px;height:9px;background:var(--text);top:3px;left:50%;border-radius:2px;transform-origin:bottom center;transform:translateX(-50%) rotate(var(--rot,0deg));}
.oct-display{font-size:9px;color:var(--text2);display:flex;align-items:center;gap:4px;margin-top:5px;justify-content:center;}
.oct-val{color:var(--accent1);}

/* ── BEAT MANAGER PANEL ── */
#beat-manager{
  position:fixed;left:0;top:0;bottom:0;z-index:600;
  width:260px;
  background:var(--panel);
  border-right:2px solid var(--accent1);
  box-shadow:4px 0 30px var(--glow),2px 0 12px rgba(0,0,0,0.5);
  display:flex;flex-direction:column;
  transform:translateX(-260px);
  transition:none;
  will-change:transform;
  user-select:none;
}
#beat-manager.transitioning{transition:transform 0.3s cubic-bezier(.4,0,.2,1);}

/* Fixed screen-edge pull tab */
#bm-handle{
  position:fixed;left:0;top:50%;transform:translateY(-50%);
  z-index:601;
  width:18px;height:88px;
  background:var(--accent1);
  border-radius:0 8px 8px 0;
  display:flex;align-items:center;justify-content:center;
  cursor:grab;
  box-shadow:3px 0 14px var(--glow);
  writing-mode:vertical-rl;
  font-size:8px;letter-spacing:0.3em;color:#fff;
  font-family:inherit;
  transition:background 0.2s,box-shadow 0.2s,opacity 0.2s,left 0.3s cubic-bezier(.4,0,.2,1);
}
#bm-handle:hover{background:var(--accent2);box-shadow:5px 0 20px var(--glow);}
#bm-handle.grabbing{cursor:grabbing;}
/* When panel is open, tab moves with it */
#bm-handle.panel-open{left:260px;}

/* Panel inner */
#bm-inner{
  flex:1;overflow-y:auto;overflow-x:hidden;padding:18px 14px 24px;
  scrollbar-width:thin;scrollbar-color:var(--accent1) transparent;
}
#bm-title{
  font-family:inherit;font-size:16px;letter-spacing:0.25em;
  color:var(--accent1);text-shadow:0 0 14px var(--glow);
  margin-bottom:4px;text-align:center;
}
#bm-subtitle{font-size:8px;color:var(--text2);letter-spacing:0.2em;text-align:center;margin-bottom:18px;}
.bm-divider{height:1px;background:var(--border);margin:14px 0;}

/* Beat Manager feature buttons */
.bm-feature{
  display:flex;flex-direction:column;gap:6px;margin-bottom:12px;
}
.bm-feat-label{font-size:8px;color:var(--text2);letter-spacing:0.2em;}
.bm-feat-btn{
  font-family:inherit;font-size:9px;letter-spacing:0.15em;
  padding:7px 12px;border:1px solid var(--border);
  background:color-mix(in srgb,var(--accent1) 8%,transparent);
  color:var(--text);cursor:pointer;border-radius:4px;
  transition:all 0.12s;text-align:left;
  display:flex;align-items:center;gap:8px;
}
.bm-feat-btn:hover{background:color-mix(in srgb,var(--accent1) 20%,transparent);border-color:var(--accent1);color:var(--accent1);}
.bm-feat-btn .bm-icon{font-size:13px;flex-shrink:0;}

/* Inline controls inside panel */
.bm-control-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.bm-knob-wrap{display:flex;flex-direction:column;align-items:center;gap:3px;}
.bm-knob{
  width:34px;height:34px;border-radius:50%;
  background:conic-gradient(var(--accent1) 0deg,var(--accent1) var(--deg,100deg),var(--border) var(--deg,100deg));
  cursor:ns-resize;border:2px solid var(--border);position:relative;
  transition:box-shadow 0.1s;
}
.bm-knob:hover{box-shadow:0 0 10px var(--glow);}
.bm-knob::after{content:'';position:absolute;width:2px;height:9px;background:var(--text);top:3px;left:50%;border-radius:2px;transform-origin:bottom center;transform:translateX(-50%) rotate(var(--rot,-135deg));}

.bm-select{
  background:var(--panel);border:1px solid var(--border);color:var(--accent1);
  font-family:inherit;font-size:9px;padding:4px 6px;border-radius:3px;
  cursor:pointer;appearance:none;letter-spacing:0.08em;flex:1;
}
.bm-val-display{font-size:11px;color:var(--accent1);min-width:28px;text-align:center;letter-spacing:0.05em;}

/* TAP TEMPO button */
#tapTempoBtn{
  font-family:inherit;font-size:10px;letter-spacing:0.15em;
