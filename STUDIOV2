}
.loop-btn.active{background:var(--accent1);border-color:var(--accent1);color:#fff;}
.loop-btn:hover:not(.active){border-color:var(--accent1);color:var(--accent1);}

/* Chord preset buttons */
.chord-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px;}
.chord-btn{
  font-family:inherit;font-size:8px;letter-spacing:0.08em;
