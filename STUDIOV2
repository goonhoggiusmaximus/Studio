<script>
// ─── GENRE DEFINITIONS ──────────────────────────────────────
const GENRES = {
  electronic: [
    {name:'SYNTH',  key:'synth'},
    {name:'BASS',   key:'bass'},
    {name:'LEAD',   key:'lead'},
    {name:'PAD',    key:'pad'},
  ],
  rock: [
    {name:'E.GTR',    key:'egtr'},
    {name:'BASS GTR', key:'bassgtr'},
    {name:'POWER',    key:'power'},
    {name:'ORGAN',    key:'organ'},
  ],
  country: [
    {name:'ACOUSTIC', key:'acoustic'},
    {name:'BANJO',    key:'banjo'},
    {name:'FIDDLE',   key:'fiddle'},
    {name:'STEEL',    key:'steel'},
  ],
};

const SCALES = {
  minor:[0,2,3,5,7,8,10,12], major:[0,2,4,5,7,9,11,12],
  pentatonic:[0,2,4,7,9,12,14,16], blues:[0,3,5,6,7,10,12,15],
};
const NOTE_NAMES=['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
let STEPS=16;

// ─── STATE ───────────────────────────────────────────────────
let bpm=90, playing=false, curStep=0, intervalId=null;
let audioCtx=null, masterGain=null, masterVol=0.85;
let currentGenre='electronic';
let swingAmt=0, grooveAmt=0; // 0–1
let masterRevSend=0, masterDelSend=0;
let masterRevNode=null, masterDelNode=null, masterRevGain=null, masterDelGain=null;

// drum pattern fixed 4 tracks
const drumPat=Array.from({length:4},()=>Array(STEPS).fill(0));

// melody patterns per genre, per track (4)
// melPat[g][ti] = array of note objects: {row, start, len}
const melPat={};
Object.keys(GENRES).forEach(g=>{
  melPat[g]=Array.from({length:4},()=>[]);
});
const melOct={};
Object.keys(GENRES).forEach(g=>{melOct[g]=[4,2,5,3];});
const instP={};
Object.keys(GENRES).forEach(g=>{
  instP[g]=GENRES[g].map(()=>({attack:0.1,release:0.4,detune:0.0,reverb:0.25}));
});

// ─── AUDIO ───────────────────────────────────────────────────
function getCtx(){
  if(!audioCtx){
    audioCtx=new(window.AudioContext||window.webkitAudioContext)();
    masterGain=audioCtx.createGain();
    masterGain.gain.value=masterVol;
    masterGain.connect(audioCtx.destination);
    // Master reverb send
    masterRevGain=audioCtx.createGain();masterRevGain.gain.value=0;
    masterRevNode=audioCtx.createConvolver();
    const rLen=audioCtx.sampleRate*3,rBuf=audioCtx.createBuffer(2,rLen,audioCtx.sampleRate);
    for(let ch=0;ch<2;ch++){const d=rBuf.getChannelData(ch);for(let i=0;i<rLen;i++)d[i]=(Math.random()*2-1)*Math.pow(1-i/rLen,2);}
    masterRevNode.buffer=rBuf;
    const revOut=audioCtx.createGain();revOut.gain.value=0.7;
    masterRevGain.connect(masterRevNode);masterRevNode.connect(revOut);revOut.connect(audioCtx.destination);
    masterGain.connect(masterRevGain);
    // Master delay send
    masterDelGain=audioCtx.createGain();masterDelGain.gain.value=0;
    masterDelNode=audioCtx.createDelay(1.0);masterDelNode.delayTime.value=60/bpm*0.5;
    const delFB=audioCtx.createGain();delFB.gain.value=0.4;
    const delOut=audioCtx.createGain();delOut.gain.value=0.55;
    masterDelGain.connect(masterDelNode);masterDelNode.connect(delFB);delFB.connect(masterDelNode);masterDelNode.connect(delOut);delOut.connect(audioCtx.destination);
    masterGain.connect(masterDelGain);
  }
  return audioCtx;
}
function dest(){return masterGain||getCtx().destination;}

let _reverb=null;
function getReverb(){
  const c=getCtx();
  if(!_reverb){
    const len=c.sampleRate*2,buf=c.createBuffer(2,len,c.sampleRate);
    for(let ch=0;ch<2;ch++){const d=buf.getChannelData(ch);for(let i=0;i<len;i++)d[i]=(Math.random()*2-1)*Math.pow(1-i/len,2.5);}
    _reverb=c.createConvolver();_reverb.buffer=buf;_reverb.connect(masterGain);
  }
  return _reverb;
}

function noteFreq(row,oct,genreKey){
  const scale=SCALES[document.getElementById('scaleSel').value];
  const keyNote=NOTE_NAMES.indexOf(document.getElementById('keySel').value);
  const semis=keyNote+scale[7-row]+(oct*12);
  return 440*Math.pow(2,(semis-69)/12);
}

// ── DRUM SOUNDS ──
function playKick(t){const c=getCtx(),o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(dest());o.frequency.setValueAtTime(155,t);o.frequency.exponentialRampToValueAtTime(0.01,t+0.45);g.gain.setValueAtTime(1,t);g.gain.exponentialRampToValueAtTime(0.001,t+0.45);o.start(t);o.stop(t+0.5);}
function playSnare(t){const c=getCtx(),buf=c.createBuffer(1,c.sampleRate*0.2,c.sampleRate),d=buf.getChannelData(0);for(let i=0;i<d.length;i++)d[i]=(Math.random()*2-1)*Math.pow(1-i/d.length,2);const s=c.createBufferSource(),g=c.createGain();s.buffer=buf;g.gain.setValueAtTime(0.8,t);g.gain.exponentialRampToValueAtTime(0.001,t+0.2);s.connect(g);g.connect(dest());s.start(t);}
function playHihat(t){const c=getCtx(),buf=c.createBuffer(1,c.sampleRate*0.06,c.sampleRate),d=buf.getChannelData(0);for(let i=0;i<d.length;i++)d[i]=(Math.random()*2-1)*Math.pow(1-i/d.length,3);const s=c.createBufferSource(),f=c.createBiquadFilter(),g=c.createGain();f.type='highpass';f.frequency.value=8000;g.gain.setValueAtTime(0.35,t);g.gain.exponentialRampToValueAtTime(0.001,t+0.06);s.buffer=buf;s.connect(f);f.connect(g);g.connect(dest());s.start(t);}
function playClap(t){const c=getCtx();for(let i=0;i<3;i++){const buf=c.createBuffer(1,c.sampleRate*0.08,c.sampleRate),d=buf.getChannelData(0);for(let j=0;j<d.length;j++)d[j]=(Math.random()*2-1)*Math.pow(1-j/d.length,1.5);const s=c.createBufferSource(),g=c.createGain();g.gain.setValueAtTime(0.5,t+i*0.012);g.gain.exponentialRampToValueAtTime(0.001,t+i*0.012+0.08);s.buffer=buf;s.connect(g);g.connect(dest());s.start(t+i*0.012);}}
const drumFns=[playKick,playSnare,playHihat,playClap];

// ── MELODY SOUNDS ──
function withReverb(g,amt){if(amt>0.1){const wet=getCtx().createGain();wet.gain.value=amt*0.5;g.connect(wet);wet.connect(getReverb());}}

// ELECTRONIC
function playSynth(f,t,p,dur){const c=getCtx(),atk=0.01+p.attack*0.3,rel=dur?Math.max(0.05,dur-atk):0.1+p.release*1.2;const o1=c.createOscillator(),o2=c.createOscillator(),g=c.createGain(),flt=c.createBiquadFilter();o1.type='sawtooth';o2.type='sawtooth';o2.detune.value=p.detune*20+5;flt.type='lowpass';flt.frequency.value=1400;flt.Q.value=5;[o1,o2].forEach(o=>{o.frequency.value=f;o.connect(flt);});flt.connect(g);g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(0.2,t+atk);g.gain.exponentialRampToValueAtTime(0.001,t+atk+rel);g.connect(dest());withReverb(g,p.reverb);o1.start(t);o2.start(t);o1.stop(t+atk+rel+0.1);o2.stop(t+atk+rel+0.1);}
function playBassSynth(f,t,p,dur){const c=getCtx(),atk=0.005+p.attack*0.1,rel=dur?Math.max(0.05,dur-atk):0.1+p.release*0.8;const o=c.createOscillator(),sub=c.createOscillator(),g=c.createGain(),flt=c.createBiquadFilter();o.type='square';sub.type='sine';o.frequency.value=f*(1+p.detune*0.02);sub.frequency.value=f*0.5;flt.type='lowpass';flt.frequency.value=600;[o,sub].forEach(s=>s.connect(flt));flt.connect(g);g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(0.35,t+atk);g.gain.exponentialRampToValueAtTime(0.001,t+atk+rel);g.connect(dest());o.start(t);sub.start(t);o.stop(t+atk+rel+0.05);sub.stop(t+atk+rel+0.05);}
function playLead(f,t,p,dur){const c=getCtx(),atk=0.005+p.attack*0.15,rel=dur?Math.max(0.05,dur-atk):0.08+p.release*0.9;const o=c.createOscillator(),g=c.createGain(),flt=c.createBiquadFilter();o.type='triangle';o.frequency.value=f;o.detune.value=p.detune*15;flt.type='bandpass';flt.frequency.value=f*2;flt.Q.value=2;o.connect(flt);flt.connect(g);g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(0.28,t+atk);g.gain.exponentialRampToValueAtTime(0.001,t+atk+rel);g.connect(dest());withReverb(g,p.reverb);o.start(t);o.stop(t+atk+rel+0.05);}
function playPad(f,t,p,dur){const c=getCtx(),atk=0.1+p.attack*0.8,rel=dur?Math.max(0.1,dur-atk):0.3+p.release*1.5;const oscs=[];for(let i=0;i<4;i++){const o=c.createOscillator();o.type=i%2===0?'sine':'triangle';o.frequency.value=f*(1+(i-1.5)*0.003+p.detune*0.015);oscs.push(o);}const g=c.createGain();g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(0.15,t+atk);g.gain.exponentialRampToValueAtTime(0.001,t+atk+rel);oscs.forEach(o=>{o.connect(g);o.start(t);o.stop(t+atk+rel+0.1);});g.connect(dest());withReverb(g,p.reverb+0.2);}

// ROCK - electric guitar (distorted), bass guitar, power chord, organ
function playEGtr(f,t,p,dur){const c=getCtx(),atk=0.005,rel=dur?Math.max(0.05,dur-atk):0.05+p.release*0.5;const o=c.createOscillator(),wave=c.createWaveShaper(),g=c.createGain(),flt=c.createBiquadFilter();o.type='sawtooth';o.frequency.value=f*(1+p.detune*0.01);const curve=new Float32Array(256);for(let i=0;i<256;i++){const x=i*2/256-1;curve[i]=x<0?-Math.pow(-x,0.5):Math.pow(x,0.5);}wave.curve=curve;flt.type='peaking';flt.frequency.value=2500;flt.gain.value=8;o.connect(wave);wave.connect(flt);flt.connect(g);g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(0.22,t+atk);g.gain.exponentialRampToValueAtTime(0.001,t+atk+rel);g.connect(dest());o.start(t);o.stop(t+atk+rel+0.05);}
function playBassGtr(f,t,p,dur){const c=getCtx(),atk=0.008,rel=dur?Math.max(0.05,dur-atk):0.1+p.release*0.7;const o=c.createOscillator(),g=c.createGain(),flt=c.createBiquadFilter();o.type='triangle';o.frequency.value=f;flt.type='lowpass';flt.frequency.value=500;o.connect(flt);flt.connect(g);g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(0.4,t+atk);g.gain.exponentialRampToValueAtTime(0.001,t+atk+rel);g.connect(dest());o.start(t);o.stop(t+atk+rel+0.05);}
function playPower(f,t,p,dur){const c=getCtx(),atk=0.01,rel=dur?Math.max(0.05,dur-atk):0.15+p.release*0.6;const freqs=[f,f*1.498,f*2];const g=c.createGain(),wave=c.createWaveShaper();const curve=new Float32Array(256);for(let i=0;i<256;i++){const x=i*2/256-1;curve[i]=Math.tanh(x*3)*0.7;}wave.curve=curve;freqs.forEach(fr=>{const o=c.createOscillator();o.type='sawtooth';o.frequency.value=fr;o.connect(wave);o.start(t);o.stop(t+atk+rel+0.1);});wave.connect(g);g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(0.18,t+atk);g.gain.exponentialRampToValueAtTime(0.001,t+atk+rel);g.connect(dest());}
function playOrgan(f,t,p,dur){const c=getCtx(),atk=0.01,rel=dur?Math.max(0.05,dur-atk):0.05+p.release*0.4;const harmonics=[1,2,3,4,6,8];const g=c.createGain();harmonics.forEach((h,i)=>{const o=c.createOscillator(),og=c.createGain();o.type='sine';o.frequency.value=f*h;og.gain.value=0.3/Math.pow(i+1,0.8);o.connect(og);og.connect(g);o.start(t);o.stop(t+atk+rel+0.1);});g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(0.25,t+atk);g.gain.exponentialRampToValueAtTime(0.001,t+atk+rel);g.connect(dest());withReverb(g,p.reverb*0.5);}

// COUNTRY - acoustic guitar, banjo, fiddle, steel guitar
function playAcoustic(f,t,p,dur){const c=getCtx(),atk=0.005,rel=dur?Math.max(0.05,dur-atk):0.1+p.release*0.7;const harmonics=[1,2,3,4,5,6];const g=c.createGain(),flt=c.createBiquadFilter();flt.type='peaking';flt.frequency.value=1800;flt.gain.value=4;harmonics.forEach((h,i)=>{const o=c.createOscillator(),og=c.createGain();o.type='sine';o.frequency.value=f*h*(1+p.detune*0.005);og.gain.value=0.35/Math.pow(h,1.2);o.connect(og);og.connect(flt);o.start(t);o.stop(t+atk+rel+0.1);});flt.connect(g);g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(0.3,t+atk);g.gain.exponentialRampToValueAtTime(0.001,t+atk+rel);g.connect(dest());}
function playBanjo(f,t,p,dur){const c=getCtx(),rel=dur||0.08+p.release*0.4;const g=c.createGain();[1,2,3,4].forEach((h,i)=>{const o=c.createOscillator(),og=c.createGain();o.type='triangle';o.frequency.value=f*h*(1+(i*0.003));og.gain.value=0.3/Math.pow(h,1.5);o.connect(og);og.connect(g);o.start(t);o.stop(t+rel);});g.gain.setValueAtTime(0.5,t);g.gain.exponentialRampToValueAtTime(0.001,t+rel);g.connect(dest());}
function playFiddle(f,t,p,dur){const c=getCtx(),atk=0.04+p.attack*0.1,rel=dur?Math.max(0.08,dur-atk):0.1+p.release*0.6;const o=c.createOscillator(),vib=c.createOscillator(),vibGain=c.createGain(),g=c.createGain();o.type='sawtooth';o.frequency.value=f;vib.frequency.value=5+p.detune*3;vibGain.gain.value=3;vib.connect(vibGain);vibGain.connect(o.frequency);o.connect(g);g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(0.22,t+atk);g.gain.exponentialRampToValueAtTime(0.001,t+atk+rel);g.connect(dest());withReverb(g,p.reverb*0.6);o.start(t);vib.start(t);o.stop(t+atk+rel+0.1);vib.stop(t+atk+rel+0.1);}
function playSteel(f,t,p,dur){const c=getCtx(),atk=0.01,rel=dur?Math.max(0.1,dur-atk):0.3+p.release*1.0;const o=c.createOscillator(),g=c.createGain(),flt=c.createBiquadFilter();o.type='sine';o.frequency.setValueAtTime(f*1.05,t);o.frequency.exponentialRampToValueAtTime(f,t+0.08);flt.type='peaking';flt.frequency.value=2200;flt.gain.value=6;o.connect(flt);flt.connect(g);g.gain.setValueAtTime(0,t);g.gain.linearRampToValueAtTime(0.28,t+atk);g.gain.exponentialRampToValueAtTime(0.001,t+atk+rel);g.connect(dest());withReverb(g,p.reverb+0.2);o.start(t);o.stop(t+atk+rel+0.1);}

const SOUND_FNS={
  synth:playSynth, bass:playBassSynth, lead:playLead, pad:playPad,
  egtr:playEGtr, bassgtr:playBassGtr, power:playPower, organ:playOrgan,
  acoustic:playAcoustic, banjo:playBanjo, fiddle:playFiddle, steel:playSteel,
};

// ─── BUILD STARS ─────────────────────────────────────────────
// ─── MATRIX RAIN ──────────────────────────────────────────────
(function(){
  const canvas=document.getElementById('matrix-bg');
  const ctx2d=canvas.getContext('2d');
  const CHARS='アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*<>{}[]';
  let cols,drops,raf;
  function resize(){
    canvas.width=window.innerWidth;canvas.height=window.innerHeight;
    cols=Math.floor(canvas.width/16);
    drops=Array.from({length:cols},()=>Math.random()*-50);
  }
  resize();
  window.addEventListener('resize',resize);
  function draw(){
    ctx2d.fillStyle='rgba(4,16,8,0.18)';
    ctx2d.fillRect(0,0,canvas.width,canvas.height);
    for(let i=0;i<cols;i++){
      const ch=CHARS[Math.floor(Math.random()*CHARS.length)];
      const y=drops[i]*16;
      // head char bright
      ctx2d.font='bold 14px "Courier Prime",monospace';
      ctx2d.fillStyle=`rgba(180,255,200,${0.7+Math.random()*0.3})`;
      ctx2d.shadowColor='#00FF88';ctx2d.shadowBlur=10;
      ctx2d.fillText(ch,i*16,y);
      // trail
      ctx2d.font='13px "Courier Prime",monospace';
      ctx2d.shadowBlur=0;
      const trailCh=CHARS[Math.floor(Math.random()*CHARS.length)];
      ctx2d.fillStyle='rgba(0,200,100,0.45)';
      ctx2d.fillText(trailCh,i*16,y-16);
      ctx2d.fillStyle='rgba(0,150,70,0.2)';
      ctx2d.fillText(CHARS[Math.floor(Math.random()*CHARS.length)],i*16,y-32);
      if(y>canvas.height&&Math.random()>0.975) drops[i]=0;
      else drops[i]+=0.5;
    }
    if(document.body.classList.contains('theme-matrix')) raf=requestAnimationFrame(draw);
  }
  // start/stop based on theme
  const observer=new MutationObserver(()=>{
    if(document.body.classList.contains('theme-matrix')){cancelAnimationFrame(raf);draw();}
    else cancelAnimationFrame(raf);
  });
  observer.observe(document.body,{attributes:true,attributeFilter:['class']});
  if(document.body.classList.contains('theme-matrix')) draw();
})();

// ─── NAUTICAL OCEAN ───────────────────────────────────────────
(function(){
  const canvas=document.getElementById('nautical-bg');
  const ctx2d=canvas.getContext('2d');
  let W,H,t=0,raf;
  function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight;}
  resize();window.addEventListener('resize',resize);

  function wave(x,t,amp,freq,speed,phase){
    return Math.sin(x*freq+t*speed+phase)*amp;
  }

  function drawScene(){
    t+=0.012;
    ctx2d.clearRect(0,0,W,H);

    // sky gradient — stormy
    const sky=ctx2d.createLinearGradient(0,0,0,H*0.55);
    sky.addColorStop(0,'#06101a');sky.addColorStop(0.4,'#0a1e2e');sky.addColorStop(1,'#0d2a3a');
    ctx2d.fillStyle=sky;ctx2d.fillRect(0,0,W,H*0.55);

    // storm clouds
    ctx2d.save();
    for(let c=0;c<6;c++){
      const cx=((c*W/4+t*12*((c%2===0)?1:-1))%(W+300))-150;
      const cy=H*0.08+Math.sin(t*0.3+c)*H*0.04;
      const cw=200+c*40;const ch=50+c*15;
      const grad=ctx2d.createRadialGradient(cx,cy,0,cx,cy,cw*0.6);
      grad.addColorStop(0,'rgba(20,35,55,0.92)');grad.addColorStop(1,'rgba(10,20,35,0)');
      ctx2d.fillStyle=grad;
      ctx2d.beginPath();ctx2d.ellipse(cx,cy,cw*0.6,ch*0.4,0,0,Math.PI*2);ctx2d.fill();
    }
    // lightning flash occasionally
    if(Math.random()>0.997){
      ctx2d.fillStyle='rgba(200,230,255,0.04)';ctx2d.fillRect(0,0,W,H*0.55);
    }
    ctx2d.restore();

    // rain streaks — cover full sky and beyond
    ctx2d.save();
    const rainCount=220;
    ctx2d.strokeStyle='rgba(140,180,220,0.22)';ctx2d.lineWidth=0.9;
    for(let r=0;r<rainCount;r++){
      const speed=180+Math.random()*60;
      const rx=((r*(W/rainCount)*1.3+t*speed*0.7)%( W+60))-30;
      const ry=((r*53+t*speed)%(H*0.56+80))%(H*0.56+80)-20;
      ctx2d.beginPath();ctx2d.moveTo(rx,ry);ctx2d.lineTo(rx+4,ry+13);ctx2d.stroke();
    }
    ctx2d.restore();

    // horizon glow
    const hY=H*0.52;
    const hg=ctx2d.createLinearGradient(0,hY-20,0,hY+20);
    hg.addColorStop(0,'rgba(0,60,100,0)');hg.addColorStop(0.5,'rgba(0,80,130,0.3)');hg.addColorStop(1,'rgba(0,40,80,0)');
    ctx2d.fillStyle=hg;ctx2d.fillRect(0,hY-20,W,40);

    // deep ocean layers (back to front)
    const waterLayers=[
      {y:0.52,amp:6,freq:0.008,spd:0.6,phase:0,   col:'#03111e'},
      {y:0.57,amp:9,freq:0.010,spd:0.8,phase:1.2, col:'#041520'},
      {y:0.63,amp:12,freq:0.012,spd:1.0,phase:2.4,col:'#051820'},
      {y:0.70,amp:16,freq:0.014,spd:1.2,phase:0.8,col:'#051a22'},
      {y:0.78,amp:20,freq:0.016,spd:1.4,phase:3.1,col:'#061c24'},
      {y:0.87,amp:24,freq:0.018,spd:1.6,phase:1.7,col:'#071e26'},
      {y:1.0, amp:0, freq:0,    spd:0,  phase:0,  col:'#071e26'},
    ];
    for(let li=0;li<waterLayers.length-1;li++){
      const la=waterLayers[li],lb=waterLayers[li+1];
      ctx2d.beginPath();
      ctx2d.moveTo(0,H);
      for(let x=0;x<=W;x+=4){
        const y=H*la.y+wave(x,t,la.amp,la.freq,la.spd,la.phase);
        if(x===0)ctx2d.moveTo(0,y);else ctx2d.lineTo(x,y);
      }
      ctx2d.lineTo(W,H);ctx2d.lineTo(0,H);ctx2d.closePath();
      ctx2d.fillStyle=lb.col;ctx2d.fill();
    }

    // whitecaps
    ctx2d.save();ctx2d.strokeStyle='rgba(180,220,255,0.22)';ctx2d.lineWidth=1.5;
    for(let w2=0;w2<12;w2++){
      const wx=((w2*W/10+t*40)%(W+100))-50;
      const wy=H*(0.54+w2*0.025)+wave(wx,t,10,0.012,1.0,w2);
      ctx2d.beginPath();
      for(let dx=0;dx<60;dx+=3){
        const wwy=wy+Math.sin(dx*0.3+t*3)*2;
        dx===0?ctx2d.moveTo(wx+dx,wwy):ctx2d.lineTo(wx+dx,wwy);
      }
      ctx2d.stroke();
    }
    ctx2d.restore();

    // ocean surface shimmer
    ctx2d.save();ctx2d.globalAlpha=0.06;
    for(let s=0;s<8;s++){
      const sx=((s*W/6+t*25)%(W+80))-40;
      const sy=H*0.56+wave(sx,t,8,0.01,0.9,s*0.7);
      ctx2d.fillStyle='rgba(100,180,255,0.8)';
      ctx2d.fillRect(sx,sy,30+s*5,2);
    }
    ctx2d.restore();

    // fishing boat
    const boatX=W*0.42+Math.sin(t*0.7)*W*0.04;
    const boatY=H*0.535+wave(boatX,t,11,0.012,1.0,0.5);
    const roll=Math.sin(t*0.9)*0.08;
    ctx2d.save();ctx2d.translate(boatX,boatY);ctx2d.rotate(roll);

    // hull
    ctx2d.beginPath();
    ctx2d.moveTo(-45,0);ctx2d.lineTo(-40,14);ctx2d.lineTo(40,14);ctx2d.lineTo(45,0);
    ctx2d.quadraticCurveTo(0,-4,-45,0);
    ctx2d.fillStyle='#2a1a0a';ctx2d.fill();
    ctx2d.strokeStyle='#4a3010';ctx2d.lineWidth=1.5;ctx2d.stroke();

    // deck
    ctx2d.fillStyle='#3a2510';ctx2d.fillRect(-38,0,76,6);

    // cabin
    ctx2d.fillStyle='#4a3520';ctx2d.fillRect(-12,-14,28,14);
    ctx2d.fillStyle='rgba(180,200,220,0.3)';ctx2d.fillRect(-8,-12,8,8);ctx2d.fillRect(4,-12,8,8);

    // mast
    ctx2d.strokeStyle='#5a4020';ctx2d.lineWidth=2.5;
    ctx2d.beginPath();ctx2d.moveTo(8,0);ctx2d.lineTo(8,-52);ctx2d.stroke();
    // boom
    ctx2d.lineWidth=1.5;ctx2d.beginPath();ctx2d.moveTo(8,-50);ctx2d.lineTo(-22,-32);ctx2d.stroke();
    ctx2d.beginPath();ctx2d.moveTo(8,-50);ctx2d.lineTo(8,-20);ctx2d.lineTo(-22,-32);ctx2d.stroke();
    // sail — billowed by wind
    const sag=6+Math.sin(t*1.2)*3;
    ctx2d.beginPath();ctx2d.moveTo(8,-48);ctx2d.quadraticCurveTo(-22+sag,-38,-20,-33);
    ctx2d.lineTo(8,-20);ctx2d.quadraticCurveTo(8+sag*0.5,-34,8,-48);
    ctx2d.fillStyle='rgba(200,195,180,0.75)';ctx2d.fill();
    ctx2d.strokeStyle='rgba(160,150,130,0.5)';ctx2d.lineWidth=0.8;ctx2d.stroke();

    // fishing line
    ctx2d.strokeStyle='rgba(200,200,180,0.4)';ctx2d.lineWidth=0.8;
    const lineX=38,lineY=4;
    ctx2d.beginPath();ctx2d.moveTo(lineX,lineY);
    ctx2d.quadraticCurveTo(lineX+15,14,lineX+10,22);ctx2d.stroke();

    ctx2d.restore();

    if(document.body.classList.contains('theme-nautical')) raf=requestAnimationFrame(drawScene);
  }
  const observer2=new MutationObserver(()=>{
    if(document.body.classList.contains('theme-nautical')){cancelAnimationFrame(raf);drawScene();}
    else cancelAnimationFrame(raf);
  });
  observer2.observe(document.body,{attributes:true,attributeFilter:['class']});
  if(document.body.classList.contains('theme-nautical')) drawScene();
})();

// ─── WINE ROSES ───────────────────────────────────────────────
(function(){
  const container=document.getElementById('wine-bg');
  // SVG rose paths — drawn inline as text characters for simplicity
