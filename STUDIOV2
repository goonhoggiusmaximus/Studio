// ── Drag-to-open panel ──
(function(){
  const panel=document.getElementById('beat-manager');
  const handle=document.getElementById('bm-handle');
  const PANEL_W=260;
  const CLOSED=-PANEL_W; // fully off screen
  const OPEN=0;          // fully open, nothing beyond this
  let dragging=false,startX=0,startTX=0,currentTX=CLOSED;

  function setTX(tx,animate){
    tx=Math.max(CLOSED,Math.min(OPEN,tx)); // clamp: never past open or past closed
    currentTX=tx;
    panel.classList.toggle('transitioning',animate);
    panel.style.transform=`translateX(${tx}px)`;
    // move handle tab with the panel's right edge
    const handleLeft=PANEL_W+tx; // 0 when closed, 260 when open
    handle.style.transition=animate?'left 0.3s cubic-bezier(.4,0,.2,1), background 0.2s, box-shadow 0.2s':'background 0.2s, box-shadow 0.2s';
    handle.style.left=Math.max(0,handleLeft)+'px';
    handle.classList.toggle('panel-open',tx===OPEN);
  }

  handle.addEventListener('mousedown',e=>{
    dragging=true;
    startX=e.clientX;
    startTX=currentTX;
    handle.classList.add('grabbing');
    e.preventDefault();
  });
  handle.addEventListener('touchstart',e=>{
    dragging=true;
    startX=e.touches[0].clientX;
    startTX=currentTX;
    e.preventDefault();
  },{passive:false});

  document.addEventListener('mousemove',e=>{
    if(!dragging)return;
    const dx=e.clientX-startX;
    setTX(startTX+dx,false);
  });
  document.addEventListener('touchmove',e=>{
    if(!dragging)return;
    const dx=e.touches[0].clientX-startX;
    setTX(startTX+dx,false);
  },{passive:false});

  function endDrag(){
    if(!dragging)return;
    dragging=false;
    handle.classList.remove('grabbing');
    // snap open if dragged past 40% of panel width, else snap closed
    if(currentTX>CLOSED+(PANEL_W*0.4)) setTX(OPEN,true);
    else setTX(CLOSED,true);
  }
  document.addEventListener('mouseup',endDrag);
  document.addEventListener('touchend',endDrag);

  // start fully closed — handle sits flush at screen left edge
  setTX(CLOSED,false);
})();

