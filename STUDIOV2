// ─── TICK ─────────────────────────────────────────────────────
function tick(){
  const c=getCtx(),now=c.currentTime;
  let hit=false;
  phCells[(curStep-1+STEPS)%STEPS].classList.remove('lit');
  phCells[curStep].classList.add('lit');

  // Swing: off-beat steps (odd) get delayed
  const stepSec=(60/bpm/4);
  const isOffBeat=(curStep%2===1);
  const swingDelay=isOffBeat?swingAmt*stepSec*0.5:0;
  // Groove: every 3rd step gets a slight push forward
  const grooveDelay=(curStep%3===2)?grooveAmt*stepSec*0.18:0;
  const tOffset=swingDelay+grooveDelay;

  // drums
  DRUM_NAMES.forEach((_,ti)=>{if(drumPat[ti][curStep]){drumFns[ti](now+tOffset);beatHitDrum(drumEls[ti][curStep]);hit=true;}});

  // melody
  const genre=currentGenre;
  GENRES[genre].forEach((tr,ti)=>{
    const notes=melPat[genre][ti];
    notes.forEach(note=>{
      // trigger on the note's start step
      if(note.start===curStep){
        const durSec=note.len*stepSec*0.92; // slight gap
        const f=noteFreq(note.row,melOct[genre][ti],genre);

        const fn=SOUND_FNS[tr.key];
        if(fn)fn(f,now+tOffset,instP[genre][ti],durSec);
        // flash the note block
        if(rollWraps[genre]&&rollWraps[genre][ti]){
          rollWraps[genre][ti].querySelectorAll('.note-block').forEach(nb=>{
            const ni=parseInt(nb.dataset.ni);
            if(melPat[genre][ti][ni]===note){
              nb.classList.add('flash-note');
              setTimeout(()=>nb.classList.remove('flash-note'),120);
            }
          });
        }
        hit=true;
      }
    });
  });

  if(hit)fireViz(curStep);
  renderViz(curStep);

  // colHl
  const pct=(curStep/STEPS*100).toFixed(2)+'%';
  colHls.forEach(h=>h.style.left=pct);

  curStep=(curStep+1)%STEPS;
}

function startPlay(){getCtx().resume();playing=true;curStep=0;cancelAnimationFrame(idleAnimId);document.getElementById('playBtn').textContent='▶ PLAYING';document.getElementById('playBtn').classList.add('on');const ms=(60/bpm/4)*1000;tick();intervalId=setInterval(tick,ms);}
function stopPlay(){if(intervalId){clearInterval(intervalId);intervalId=null;}playing=false;document.getElementById('playBtn').textContent='▶ PLAY';document.getElementById('playBtn').classList.remove('on');phCells.forEach(c=>c.classList.remove('lit'));colHls.forEach(h=>h.style.left='0%');curStep=0;vizBars.forEach(b=>{b.style.height='3px';b.style.opacity='0.3';});idleViz();}
