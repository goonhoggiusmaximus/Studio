function randMelody(){
  const genre=currentGenre;
  GENRES[genre].forEach((tr,ti)=>{
    melPat[genre][ti]=[];
    const den=tr.key==='pad'||tr.key==='steel'?0.18:0.38;
    let lr=4,si=0;
    while(si<STEPS){
      if(Math.random()<den){
        const r=Math.random();
        lr=r<0.5?lr:r<0.8?Math.max(0,Math.min(7,lr+(Math.random()>0.5?1:-1))):Math.floor(Math.random()*8);
        const len=Math.random()<0.3?2:Math.random()<0.15?4:1;
        melPat[genre][ti].push({row:lr,start:si,len:Math.min(len,STEPS-si)});
        // occasionally add a chord note on the same step
        if(Math.random()<0.2){
          const chordRow=Math.max(0,Math.min(7,lr+(Math.random()>0.5?2:-2)));
          if(chordRow!==lr) melPat[genre][ti].push({row:chordRow,start:si,len:Math.min(len,STEPS-si)});
        }
